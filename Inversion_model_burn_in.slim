initialize() {

	if (!exists("Rep")) defineConstant("Rep",1);  // Identifier of the simulation amongst simulations with identical parameters
	defineConstant("FileName","output_test_N1_20e3_N2_20e3_chrom_length_3e3_inv_length_2e3_m_0005_scaling_5");  // Suffix for the name of the generated files
	if (!exists("AnalysisName")) defineConstant("AnalysisName","NoAnalysis");   // Name of the analysis for differentiating simulations with identical sets of parameters
	defineConstant("AnalysisNumber", 1);  // ID of the Analysis
	defineConstant("Q", 5.0);  // Scaling factor

	if (!exists("Mu")) defineConstant("Mu",1e-5);  // Mutation rate
	if (!exists("R")) defineConstant("R",1e-5);   // Recombination rate
	defineConstant("L",3e3);   // Sequence length
	if (!exists("I")) defineConstant("I",0.05);  // Initial proportion of inverted arrangements in population 2
	defineConstant("INV_LENGTH",2e3);   // Inversion length
	defineConstant("INV_START", asInteger(L/2 - INV_LENGTH/2));  // Beginning position of the inversion
	defineConstant("INV_END", INV_START + INV_LENGTH - 1);  // End position of the inversion
	defineConstant("Double_Crossover",F);  // Boolean for inclusion or exclusion of double crossovers
	defineConstant("Reverse_Mutations",F); // Boolean for inclusion of back-mutations

	// -- Demographic parameters --
	
	defineConstant("N1",20e3);  // Population sizes
	defineConstant("N2",20e3);
	defineConstant("N3",N2);
	defineConstant("m12",0.005);   // Migration rate from population P1 to P2
	defineConstant("m13",m12);   // Migration rate from population P1 to P3
	defineConstant("thirdPopControl", F);	// Boolean describing whether there is a third population or not

	// -- Deleterious Mutations --

	if (!exists("H")) defineConstant("H",0.0);  // Dominance of the mutations
	if (!exists("S")) defineConstant("S", -0.001); // Selection coefficient for the mutations

	// -- Inversion parameters --
	defineConstant("H_INV",0.5);  // Dominance of the inversion
	if (!exists("S_INV")) defineConstant("S_INV", 0.05); // Selection coefficient for the inversion


	// -- Time parameters
	defineConstant("T_MAX", 150e3); // Time of simulation end
	defineConstant("LOG_INTERVAL", 1e3); // Time interval for logging inversion frequencies and number of deleterious mutations
	defineConstant("T_INV", 50e3);  // Burn-in time before introducing inversions
	

	// --- Scaled Parameters --- 

	// Population & Time: Divide by Q
	defineConstant("N1_scaled", asInteger(N1 / Q));
	defineConstant("N2_scaled", asInteger(N2 / Q));
	defineConstant("N3_scaled", asInteger(N3 / Q));
    defineConstant("T_MAX_scaled", asInteger(T_MAX / Q));
	defineConstant("LOG_INTERVAL_scaled", asInteger(LOG_INTERVAL / Q));
    defineConstant("T_INV_scaled", asInteger(T_INV / Q));

	// Rates & Selection: Multiply by Q
	defineConstant("S_scaled", S * Q);
    defineConstant("S_INV_scaled", S_INV * Q);
    defineConstant("Mu_scaled", Mu * Q);
    defineConstant("R_scaled", R * Q);
	defineConstant("m12_scaled", m12 * Q);
	defineConstant("m13_scaled", m13 * Q);

	// Safety check: ensure fitness is strictly positive
	if (1+S*Q <= 0)	stop("Scaling Error: Scaled deleterious selection coefficient makes individuals lethal (1+S<=0).");
	if (1+S_INV*Q <= 0) stop("Scaling Error: Scaled inversion selection coefficient makes individuals lethal (1+S_INV<=0).");


	// -- Mutation Type Definitions: to model biallelic loci --
	
	initializeMutationType("m1", H, "f", S_scaled);   // Defining deleterious mutations
	m1.convertToSubstitution = F;    // Allowing loci to have back-mutations after one allele is fixed
	m1.color = "red";
	
	initializeMutationType("m2",H,"f",S_scaled);   // Mutations that will be created in the haplosome
	m2.convertToSubstitution = F;      // Same as earlier
	m2.color = "cornflowerblue";
	

	// Markers for the chromosomal inversion boundaries
	initializeMutationType("m3",H_INV,"f",S_INV_scaled);   // Start marker
	initializeMutationType("m4",H_INV,"f",0.0);   // End marker
	c(m3,m4).convertToSubstitution = T;    // Inversion can get fixed, replace by F if we wanted double/back-inversions
	c(m3,m4).color = "yellow";
	
	
	initializeGenomicElementType("g1", m2, 1.0);    // Defining the genomic element on which deleterious mutations will appear
	initializeGenomicElement(g1, 0,L-1); // uniform chromosome with uniform recombination
	

	initializeMutationRate(Mu_scaled);

	initializeRecombinationRate(R_scaled);

}

1 early() {
	// Create subpopulations
	sim.addSubpop("p1", N1_scaled);
	sim.addSubpop("p2", N2_scaled);  // Creating 2 or 3 subpopulations
	if(thirdPopControl==T) sim.addSubpop("p3", N3_scaled);
	
	// Apply migration rates between populations
	p2.setMigrationRates(p1,m12_scaled);    // Setting the migration rate from the continent to the island
	if(thirdPopControl==T) p3.setMigrationRates(p1, m13_scaled);   	// migration p1 -> p3 (non-inversion island)

	// -- Mutation Template Generation --

	target = p1.haplosomes[0];
	target.addNewDrawnMutation(m1, 0:(L-1));  // Adding mutations on the haplosomes
	defineConstant("MUT", target.mutations);   // Creating the structure that will be used in all haplosomes
	target.removeMutations();   // Removing mutations, all haplosomes will be "aa" by default
}

mutation(m2) {
	if (haplosome.containsMarkerMutation(m1,mut.position))
		return Reverse_Mutations;
	return MUT[mut.position];
}

late() {
	m2muts = sim.mutationsOfType(m2);   // Implementing back-mutations from A to a
	
	// do we have any m2 mutations segregating?
	// if so, we have m1/m2 stacked mutations to remove
	if (m2muts.length() > 0)
	{
		haplosomes = sim.subpopulations.haplosomes;
		counts = haplosomes.countOfMutationsOfType(m2);
		hasStacked = haplosomes[counts > 0];
		
		for (haplosome in hasStacked)
		{
			stacked_m2 = haplosome.mutationsOfType(m2);
			stackPositions = stacked_m2.position;
			all_m1 = haplosome.mutationsOfType(m1);
			s = (match(all_m1.position, stackPositions) >= 0);
			stacked_m1 = all_m1[s];
			haplosome.removeMutations(c(stacked_m2, stacked_m1));
		}
	}
		
}


T_INV late() {
	sim.outputMutations(sim.mutationsOfType(m1),filePath="./del_mutations_beginning_200k_h0.txt",append=F);
	writeFile("./fitness_p1_beginning_20k_h0.txt",paste(sim.cycle),append=T);
	writeFile("./fitness_p2_beginning_20k_h0.txt",paste(sim.cycle),append=T);
	sim.outputFull("./burn_in_200k_h0.txt");
}
