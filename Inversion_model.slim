// Modelling chromosomal inversions in bi-allelic populations (continent-island model)
initialize() {
	// setSeed(9151250013170199950);

	if (!exists("Rep")) defineConstant("Rep",1);  // Identifier of the simulation amongst simulations with identical parameters
	defineConstant("FileName","output_test_N1_20e3_N2_20e3_chrom_length_3e3_inv_length_2e3_recrate_1e-5_S_0001_m_0005_freqinv_005_scaling_5");  // Suffix for the name of the generated files
	if (!exists("AnalysisName")) defineConstant("AnalysisName","NoAnalysis");   // Name of the analysis for differentiating simulations with identical sets of parameters
	defineConstant("Q", 5.0);  // Scaling factor

	if (!exists("Mu")) defineConstant("Mu",1e-5);  // Mutation rate
	defineConstant("R",1e-5);   // Recombination rate
	defineConstant("L",3e3);   // Sequence length
	defineConstant("I",0.05);  // Initial proportion of inverted arrangements in population 2
	defineConstant("INV_LENGTH",2e3);   // Inversion length
	defineConstant("INV_START", asInteger(L/2 - INV_LENGTH/2));  // Beginning position of the inversion
	defineConstant("INV_END", INV_START + INV_LENGTH - 1);  // End position of the inversion
	defineConstant("Double_Crossover",F);  // Boolean for inclusion or exclusion of double crossovers

	// -- Demographic parameters --
	
	defineConstant("N1",20e3);  // Population sizes
	defineConstant("N2",20e3);
	defineConstant("N3",N2);
	defineConstant("m12",0.005);   // Migration rate from population P1 to P2
	defineConstant("m13",m12);   // Migration rate from population P1 to P3
	defineConstant("thirdPopControl", F);	// Boolean describing whether there is a third population or not

	// -- Deleterious Mutations --

	if (!exists("H")) defineConstant("H",0.0);  // Dominance of the mutations
	defineConstant("S", -0.001); // Selection coefficient for the mutations

	// -- Inversion parameters --
	defineConstant("H_INV",0.5);  // Dominance of the inversion
	if (!exists("S_INV")) defineConstant("S_INV", 0.05); // Selection coefficient for the inversion


	// -- Time parameters
	defineConstant("T_MAX", 150e3); // Time of simulation end
	defineConstant("LOG_INTERVAL", 5e3); // Time interval for logging inversion frequencies and number of deleterious mutations
	defineConstant("T_INV", 50e3);  // Burn-in time before introducing inversions
	

	// --- Scaled Parameters --- 

	// Population & Time: Divide by Q
	defineConstant("N1_scaled", asInteger(N1 / Q));
	defineConstant("N2_scaled", asInteger(N2 / Q));
	defineConstant("N3_scaled", asInteger(N3 / Q));
    defineConstant("T_MAX_scaled", asInteger(T_MAX / Q));
	defineConstant("LOG_INTERVAL_scaled", asInteger(LOG_INTERVAL / Q));
    defineConstant("T_INV_scaled", asInteger(T_INV / Q));

	// Rates & Selection: Multiply by Q
	defineConstant("S_scaled", S * Q);
    defineConstant("S_INV_scaled", S_INV * Q);
    defineConstant("Mu_scaled", Mu * Q);
    defineConstant("R_scaled", R * Q);
	defineConstant("m12_scaled", m12 * Q);
	defineConstant("m13_scaled", m13 * Q);

	// Safety check: ensure fitness is strictly positive
	if (1+S*Q <= 0)	stop("Scaling Error: Scaled deleterious selection coefficient makes individuals lethal (1+S<=0).");
	if (1+S_INV*Q <= 0) stop("Scaling Error: Scaled inversion selection coefficient makes individuals lethal (1+S_INV<=0).");


	// -- Mutation Type Definitions: to model biallelic loci --
	
	initializeMutationType("m1", H, "f", S_scaled);   // Defining deleterious mutations
	m1.convertToSubstitution = F;    // Allowing loci to have back-mutations after one allele is fixed
	m1.color = "red";
	
	initializeMutationType("m2",H,"f",S_scaled);   // Mutations that will be created in the haplosome
	m2.convertToSubstitution = F;      // Same as earlier
	m2.color = "cornflowerblue";
	

	// Markers for the chromosomal inversion boundaries
	initializeMutationType("m3",H_INV,"f",S_INV_scaled);   // Start marker
	initializeMutationType("m4",H_INV,"f",0.0);   // End marker
	c(m3,m4).convertToSubstitution = T;    // Inversion can get fixed, replace by F if we wanted double/back-inversions
	c(m3,m4).color = "yellow";
	
	
	initializeGenomicElementType("g1", m2, 1.0);    // Defining the genomic element on which deleterious mutations will appear
	initializeGenomicElement(g1, 0,L-1); // uniform chromosome with uniform recombination
	

	initializeMutationRate(Mu_scaled);

	initializeRecombinationRate(R_scaled);

}


1 early() {
	// Create subpopulations
	sim.addSubpop("p1", N1_scaled);
	sim.addSubpop("p2", N2_scaled);  // Creating 2 or 3 subpopulations
	if(thirdPopControl==T) sim.addSubpop("p3", N3_scaled);
	
	// Apply migration rates between populations
	p2.setMigrationRates(p1,m12_scaled);    // Setting the migration rate from the continent to the island
	if(thirdPopControl==T) p3.setMigrationRates(p1, m13_scaled);   	// migration p1 -> p3 (non-inversion island)

	// -- Mutation Template Generation --

	target = p1.haplosomes[0];
	target.addNewDrawnMutation(m1, 0:(L-1));  // Adding mutations on the haplosomes
	defineConstant("MUT", target.mutations);   // Creating the structure that will be used in all haplosomes
	target.removeMutations();   // Removing mutations, all haplosomes will be "aa" by default
	

	// -- Logging Setup --

	updateGlobal();  // Creating all global variables used in the logging file


	// -- Log results --
	defineConstant("log",community.createLogFile(paste("/home/taubier/Documents/SAUVEGARDES_STAGIAIRES/Kilian/Results/Result_files/freq_",FileName,"H",H,"S_INV",S_INV,"Mu",Mu,"Rep",Rep,AnalysisName,".csv"), logInterval = LOG_INTERVAL_scaled));
	log.addTick();
	log.addCustomColumn("freq_I","freq_I;");  // Frequency of the inverted arrangement amongst haplosomes 

	log.addCustomColumn("freq_II","freq_II;"); // Frequencies of arrangement karyotypes amongst individuals (II representing an inverted homokaryotype, IN a heterokaryotype and NN a non-inverted homokaryotype)
	log.addCustomColumn("freq_IN","freq_IN;"); 
	log.addCustomColumn("freq_NN","freq_NN;"); 

	log.addCustomColumn("number_haplosomes_I", "number_haplosomes_I;"); // Number of haplosomes with the inverted arrangement
	log.addCustomColumn("number_haplosomes_N", "number_haplosomes_N;"); // Number of haplosomes with the non_inverted arrangement

	log.addCustomColumn("number_mutations_I","number_mutations_I;"); // Number of deleterious mutations within the inversion region for an inverted haplosome
	log.addCustomColumn("number_mutations_N","number_mutations_N;"); // Number of deleterious mutations within the inversion region for a non_inverted haplosome
	
	log.addCustomColumn("marginal_fitness_inversion_I","marginal_fitness_inversion_I;"); // Marginal fitness of the inverted arrangement caused by the inversion (without any mutation)
    log.addCustomColumn("marginal_fitness_inversion_N","marginal_fitness_inversion_N;"); // Marginal fitness of the non-inverted arrangement caused by the inversion (without any mutation)

	log.addCustomColumn("mean_fitness_mutation_II","mean_fitness_mutation_II;"); // Mean fitnesses caused by mutation (independently from the inversion) in arrangement karyotypes
	log.addCustomColumn("mean_fitness_mutation_IN","mean_fitness_mutation_IN;");
	log.addCustomColumn("mean_fitness_mutation_NN","mean_fitness_mutation_NN;");

	log.addCustomColumn("fitness_load_I","fitness_load_I;"); // Fitness loads caused by deleterious mutations (independently from the inversion) in arrangements    (= 1 - marginal fitnesses caused by mutations only)
	log.addCustomColumn("fitness_load_N","fitness_load_N;");

	log.addCustomColumn("freq_homozygous_mut_II","freq_homozygous_mut_II;"); // Frequencies of homozygous positions for the deleterious mutations within the inversion region
	log.addCustomColumn("freq_homozygous_mut_IN","freq_homozygous_mut_IN;");
	log.addCustomColumn("freq_homozygous_mut_NN","freq_homozygous_mut_NN;");

	log.addCustomColumn("mean_fitness_global_II","mean_fitness_global_II;"); // Global mean fitnesses (including both mutations and the inversion) in arrangement karyotypes
	log.addCustomColumn("mean_fitness_global_IN","mean_fitness_global_IN;");
	log.addCustomColumn("mean_fitness_global_NN","mean_fitness_global_NN;");

	log.addCustomColumn("covariance_mutation_inversion_I","covariance_mutation_inversion_I;"); // Covariances between inversion and mutation fitnesses within an arrangement
	log.addCustomColumn("covariance_mutation_inversion_N","covariance_mutation_inversion_N;");

	log.addCustomColumn("covariance_out_of_marginal_fitness_I","covariance_out_of_marginal_fitness_I;"); // Relative strength of the interaction between mutation and inversion comparing with the marginal fitnesses of both forces independently for both arrangements
	log.addCustomColumn("covariance_out_of_marginal_fitness_N","covariance_out_of_marginal_fitness_N;");

	log.addCustomColumn("effective_selection","effective_selection;"); // Effective selection (selection coefficient if the inversion was represented by a single position)
	log.addCustomColumn("effective_selection_formula","effective_selection_formula;");  // Effective selection predicted by theory
	log.addCustomColumn("effective_dominance","effective_dominance;"); // Effective dominance (dominance coefficient if the inversion was represented by a single position)
	log.addCustomColumn("gamma","gamma;");
	log.addCustomColumn("dominance_variance","dominance_variance;"); // Variance that is not explained by additive fitness effects
	
	log.addSuppliedColumn("extinction_time");


	// Proportion of simulations with inverted haplosomes still existing (in Bash)
}

T_INV_scaled late() {
	inverted = sample(p2.haplosomes,asInteger(2*I*N2_scaled));    // Inverting some of the haplosomes
	inverted.addNewDrawnMutation(m3, INV_START);
	inverted.addNewDrawnMutation(m4, INV_END);
}

// Replacing the SLiM default mutation function by one that returns the opposite allele from the one previously present
mutation(m2) {
	if (haplosome.containsMarkerMutation(m1,mut.position))
		return T;
	return MUT[mut.position];
}

T_INV_scaled:T_MAX_scaled late() {
	if (sim.countOfMutationsOfType(m3)==0) {
		log.setSuppliedValue("extinction_time",sim.cycle);
		log.logRow();
		writeFile("/home/taubier/Documents/SAUVEGARDES_STAGIAIRES/Kilian/Results/Result_files/last_generation.txt",paste("Time of loss of the inversion","(Rep ",Rep,"): ", sim.cycle));   // Exporting into a file the time of loss of the inversion, 
		sim.simulationFinished();
	}
}

recombination() {
	gm1 = haplosome1.containsMarkerMutation(m3, INV_START);
	gm2 = haplosome2.containsMarkerMutation(m3, INV_START);

	if (!(gm1 | gm2)) {
		// homozygote non-inverted: recombination is not affected
		return F;
	}
	inInv = (breakpoints > INV_START) & (breakpoints <= INV_END);
	if (Double_Crossover) {
		if (sum(inInv) % 2 == 0) {
			return F;  // if there is an even number of recombinations in the inversion; it leads to viable gametes, therefore recombination may not be suppressed
		}
		if (gm1 & gm2) {
		// homozygote inverted: 2 breakpoints are added at the beginning and the end of the inversion to get the correct base at both ends of the inversion
			left = (breakpoints == INV_START);
			right = (breakpoints == INV_END + 1);
			breakpoints = sort(c(breakpoints[!(left | right)],
				c(INV_START, INV_END + 1)[c(sum(left) == 0, sum(right) == 0)]));   // sort them in the right order depending on the haplosome arrangement
			return T;
		} else {
			// heterozygote inverted: resample to get an even # of breakpoints
			// this is *recursive*: it calls this recombination callback again!
			breakpoints = sim.chromosomes.drawBreakpoints(individual);
		}
		return T;
	} else {
		if (!any(inInv)) {
			return F;
		}
		if (sum(inInv) % 2 == 0) {
			if (gm1 != gm2) {
				breakpoints = breakpoints[!inInv];
				return T; 
			} else {
				return F;
			}
		}  
		if (gm1 & gm2) {
			// homozygote inverted: 2 breakpoints are added at the beginning and the end of the inversion to get the correct base at both ends of the inversion
			left = (breakpoints == INV_START);
			right = (breakpoints == INV_END + 1);
			breakpoints = sort(c(breakpoints[!(left | right)],
				c(INV_START, INV_END + 1)[c(sum(left) == 0, sum(right) == 0)]));   // sort them in the right order depending on the haplosome arrangement
			return T;
		} else {
			breakpoints = breakpoints[!inInv];
			return T;  
		}	
	}	
}


late() {
	m2muts = sim.mutationsOfType(m2);   // Implementing back-mutations from A to a
	
	// do we have any m2 mutations segregating?
	// if so, we have m1/m2 stacked mutations to remove
	if (m2muts.length() > 0)
	{
		haplosomes = sim.subpopulations.haplosomes;
		counts = haplosomes.countOfMutationsOfType(m2);
		hasStacked = haplosomes[counts > 0];
		
		for (haplosome in hasStacked)
		{
			stacked_m2 = haplosome.mutationsOfType(m2);
			stackPositions = stacked_m2.position;
			all_m1 = haplosome.mutationsOfType(m1);
			s = (match(all_m1.position, stackPositions) >= 0);
			stacked_m1 = all_m1[s];
			haplosome.removeMutations(c(stacked_m2, stacked_m1));
		}
	}

	if (sim.cycle % LOG_INTERVAL_scaled == 0)
	{
		updateGlobal();
	}

		
}

// Simulation stop
T_MAX_scaled late() {
 }


 // -- Utility functions --


 // Calculating mean fitnesses caused by mutations in a population
function (float)Fitness(No<Individual> individuals) {
	if (individuals.size() == 0) {
		return(0/0);
	}
	a = asFloat(1:(individuals.size()));
	for (i in (1:(individuals.size()))) {
		homozygous_mut = individuals[i-1].mutationsFromHaplosomes("homozygous",m1);
		heterozygous_mut = individuals[i-1].mutationsFromHaplosomes("heterozygous",m1);
		homozygous_mutations_number = homozygous_mut[(homozygous_mut.position >= INV_START) & (homozygous_mut.position <= INV_END)].size();
		heterozygous_mutations_number = heterozygous_mut[(heterozygous_mut.position >= INV_START) & (heterozygous_mut.position <= INV_END)].size();
		a[i-1] = (1+S_scaled)^(homozygous_mutations_number)*(1+H*S_scaled)^(heterozygous_mutations_number);   // Calculating fitnesses corresponding to individuals
	}
	return(mean(a));
}

function (float) AnalyticalEffectiveSelection(No<Individual> individuals) {
	if (individuals.size() == 0) {
		return(0/0);
	}
	a = asFloat(1:(individuals.size()));
	for (i in (1:(individuals.size()))) {
		homozygous_mut = individuals[i-1].mutationsFromHaplosomes("homozygous",m1);
		heterozygous_mut = individuals[i-1].mutationsFromHaplosomes("heterozygous",m1);
		homozygous_mutations_number = homozygous_mut[(homozygous_mut.position >= INV_START) & (homozygous_mut.position <= INV_END)].size();
		heterozygous_mutations_number = heterozygous_mut[(heterozygous_mut.position >= INV_START) & (heterozygous_mut.position <= INV_END)].size();
		a[i-1] = S_INV_scaled + S_scaled*homozygous_mutations_number + H*S_scaled*heterozygous_mutations_number;   // Calculating fitnesses corresponding to individuals
	}
	return(mean(a));
}


function (void)updateGlobal(void) {     // Updating all global variables

	p2Individuals = sim.subpopulations[1].individuals;

	II_individuals = p2Individuals[p2Individuals.countOfMutationsOfType(m3) == 2];     // Separating II, IN and NN individuals
	IN_individuals = p2Individuals[p2Individuals.countOfMutationsOfType(m3) == 1];
	NN_individuals = p2Individuals[p2Individuals.countOfMutationsOfType(m3) == 0];

	haplosomes = p2.haplosomes;
	counts = haplosomes.countOfMutationsOfType(m3);

	inv = haplosomes[counts > 0];  // Separating inverted and non_inverted haplosomes
	non_inv = haplosomes[counts == 0];

	pos_inv = inv.positionsOfMutationsOfType(m1);   // Identifying the positions of mutations for both arrangements
	pos_non_inv = non_inv.positionsOfMutationsOfType(m1);

	defineGlobal("freq_I", sum(p2Individuals.countOfMutationsOfType(m3))/(p2.haplosomes.size()));
	defineGlobal("freq_II",II_individuals.size()/(p2Individuals.size()));
	defineGlobal("freq_IN",IN_individuals.size()/(p2Individuals.size()));
	defineGlobal("freq_NN",NN_individuals.size()/(p2Individuals.size()));

	homozygous_mut_II = II_individuals.mutationsFromHaplosomes("homozygous",m1);  // Identifying the homozygous and heterozygous positions for mutations in inverted homokaryotypes
	heterozygous_mut_II = II_individuals.mutationsFromHaplosomes("heterozygous",m1);
	all_mut_II = II_individuals.mutationsFromHaplosomes("all",m1);
	
	homozygous_mut_IN = IN_individuals.mutationsFromHaplosomes("homozygous",m1); // Identifying the homozygous and heterozygous positions for mutations in heterokaryotypes
	heterozygous_mut_IN = IN_individuals.mutationsFromHaplosomes("heterozygous",m1);
	all_mut_IN = IN_individuals.mutationsFromHaplosomes("all",m1);
	
	homozygous_mut_NN = NN_individuals.mutationsFromHaplosomes("homozygous",m1); // Identifying the homozygous and heterozygous positions for mutations in non-inverted homokaryotypes
	heterozygous_mut_NN = NN_individuals.mutationsFromHaplosomes("heterozygous",m1);
	all_mut_NN = NN_individuals.mutationsFromHaplosomes("all",m1);

	// Making all the counts for those positions

	homozygous_mutations_number_II = homozygous_mut_II[(homozygous_mut_II.position >= INV_START) & (homozygous_mut_II.position <= INV_END)].size(); 
	heterozygous_mutations_number_II = heterozygous_mut_II[(heterozygous_mut_II.position >= INV_START) & (heterozygous_mut_II.position <= INV_END)].size();
	total_mutations_number_II = all_mut_II[(all_mut_II.position >= INV_START) & (all_mut_II.position <= INV_END)].size();
	
	homozygous_mutations_number_IN = homozygous_mut_IN[(homozygous_mut_IN.position >= INV_START) & (homozygous_mut_IN.position <= INV_END)].size();
	heterozygous_mutations_number_IN = heterozygous_mut_IN[(heterozygous_mut_IN.position >= INV_START) & (heterozygous_mut_IN.position <= INV_END)].size();
	total_mutations_number_IN = all_mut_IN[(all_mut_IN.position >= INV_START) & (all_mut_IN.position <= INV_END)].size();
	
	homozygous_mutations_number_NN = homozygous_mut_NN[(homozygous_mut_NN.position >= INV_START) & (homozygous_mut_NN.position <= INV_END)].size();
	heterozygous_mutations_number_NN = heterozygous_mut_NN[(heterozygous_mut_NN.position >= INV_START) & (heterozygous_mut_NN.position <= INV_END)].size();
	total_mutations_number_NN = all_mut_NN[(all_mut_NN.position >= INV_START) & (all_mut_NN.position <= INV_END)].size();

	defineGlobal("freq_homozygous_mut_II",homozygous_mutations_number_II/(homozygous_mutations_number_II + heterozygous_mutations_number_II)); // Frequencies of homozygous positions amongst those with mutations in arrangement karyotypes
	defineGlobal("freq_homozygous_mut_IN",homozygous_mutations_number_IN/(homozygous_mutations_number_IN + heterozygous_mutations_number_IN));
	defineGlobal("freq_homozygous_mut_NN",homozygous_mutations_number_NN/(homozygous_mutations_number_NN + heterozygous_mutations_number_NN));


  // Case when inversion is fixed (see the inversion polymorphism case for explanations)

	if (freq_I == 1) {  // Some variables make no sense if there is no non-inverted haplosome, these will not be plotted

		defineGlobal("number_haplosomes_I", inv.size());
		defineGlobal("number_haplosomes_N",non_inv.size());

		defineGlobal("number_mutations_I", sum((pos_inv >= INV_START) & (pos_inv <= INV_END))/(inv.size()));
		defineGlobal("number_mutations_N",0/0);


		defineGlobal("marginal_fitness_inversion_I", 0/0);
		defineGlobal("marginal_fitness_inversion_N", 0/0);

		defineGlobal("mean_fitness_mutation_II", Fitness(II_individuals));
		defineGlobal("mean_fitness_mutation_IN",0/0);
		defineGlobal("mean_fitness_mutation_NN", 0/0);

		defineGlobal("fitness_load_I", 1-(mean_fitness_mutation_II*freq_I + mean_fitness_mutation_IN*(1-freq_I)));
		defineGlobal("fitness_load_N",0/0);

		defineGlobal("mean_fitness_global_II", (1+S_INV_scaled)*Fitness(II_individuals));
		defineGlobal("mean_fitness_global_IN", 0/0);
		defineGlobal("mean_fitness_global_NN", 0/0);

		defineGlobal("covariance_mutation_inversion_I", 0/0);
		defineGlobal("covariance_mutation_inversion_N",0/0);

		defineGlobal("covariance_out_of_marginal_fitness_I",0/0);
		defineGlobal("covariance_out_of_marginal_fitness_N",0/0);

		defineGlobal("covariance_out_of_marginal_fitness_I",0/0);
		defineGlobal("covariance_out_of_marginal_fitness_N",0/0);

		defineGlobal("effective_selection",0/0);
		defineGlobal("effective_selection_formula",0/0);
		defineGlobal("effective_dominance",0/0);
		defineGlobal("gamma",0/0);
		defineGlobal("dominance_variance",0/0);
	}
	// Case when the inversion is lost
	else { 
		if (freq_I == 0) {   // Some variables make no sense if there is no inversion, these will not be plotted
			
			defineGlobal("number_haplosomes_I", inv.size());
			defineGlobal("number_haplosomes_N",non_inv.size());

			defineGlobal("number_mutations_I", 0/0);
			defineGlobal("number_mutations_N", sum((pos_non_inv >= INV_START) & (pos_non_inv <= INV_END))/(non_inv.size()));

			defineGlobal("marginal_fitness_inversion_I", 0/0);
			defineGlobal("marginal_fitness_inversion_N", 0/0);

			defineGlobal("mean_fitness_mutation_II",0/0);
			defineGlobal("mean_fitness_mutation_IN", 0/0);
			defineGlobal("mean_fitness_mutation_NN",Fitness(NN_individuals));

			defineGlobal("fitness_load_I", 0/0);
			defineGlobal("fitness_load_N", 1-(mean_fitness_mutation_IN*freq_I + mean_fitness_mutation_NN*(1-freq_I)));

			defineGlobal("mean_fitness_global_II", 0/0);
			defineGlobal("mean_fitness_global_IN", 0/0);
			defineGlobal("mean_fitness_global_NN", 1*Fitness(NN_individuals));

			defineGlobal("covariance_mutation_inversion_I",0/0);
			defineGlobal("covariance_mutation_inversion_N", 0/0);

			defineGlobal("covariance_out_of_marginal_fitness_I",0/0);
			defineGlobal("covariance_out_of_marginal_fitness_N",0/0);

			defineGlobal("covariance_out_of_marginal_fitness_I",0/0);
			defineGlobal("covariance_out_of_marginal_fitness_N",0/0);

			defineGlobal("effective_selection",0/0);
			defineGlobal("effective_selection_formula",0/0);
			defineGlobal("effective_dominance",0/0);
			defineGlobal("gamma",0/0);
			defineGlobal("dominance_variance",0/0);
		} 
		// Case of inversion polymorphism
		else {

			defineGlobal("number_haplosomes_I", inv.size());   // Number of haplosomes per arrangement
			defineGlobal("number_haplosomes_N",non_inv.size());

			defineGlobal("number_mutations_I", sum((pos_inv >= INV_START) & (pos_inv <= INV_END))/(inv.size()));  // Number of mutations within the inversion region for both arrangements
			defineGlobal("number_mutations_N", sum((pos_non_inv >= INV_START) & (pos_non_inv <= INV_END))/(non_inv.size()));

			defineGlobal("marginal_fitness_inversion_I", (1+S_INV_scaled)*freq_I + (1+H_INV*S_INV_scaled)*(1-freq_I)); // Marginal fitness only with inversion only (no mutations) for both arrangements
			defineGlobal("marginal_fitness_inversion_N", 1*(1-freq_I)+(1+H_INV*S_INV_scaled)*freq_I); 

			defineGlobal("mean_fitness_mutation_II", Fitness(II_individuals));  // Mean fitness linked to mutations only (no inversion) for different arrangement karyotypes
			defineGlobal("mean_fitness_mutation_IN", Fitness(IN_individuals));
			defineGlobal("mean_fitness_mutation_NN", Fitness(NN_individuals));

			defineGlobal("fitness_load_I", 1-(mean_fitness_mutation_II*freq_I + mean_fitness_mutation_IN*(1-freq_I))); // Fitness load linked to mutations only (no inversion) for both arrangements
			defineGlobal("fitness_load_N", 1-(mean_fitness_mutation_IN*freq_I + mean_fitness_mutation_NN*(1-freq_I)));

			defineGlobal("mean_fitness_global_II", (1+S_INV_scaled)*Fitness(II_individuals)); // Global mean fitness (inversion + mutations) for differents arrangement karyotypes
			defineGlobal("mean_fitness_global_IN", (1+H_INV*S_INV_scaled)*Fitness(IN_individuals));
			defineGlobal("mean_fitness_global_NN", 1*Fitness(NN_individuals));

			defineGlobal("covariance_mutation_inversion_I", freq_I*(1-freq_I)*(1-H_INV)*S_INV_scaled*(mean_fitness_mutation_II-mean_fitness_mutation_IN)); // Covariance between mutation and inversion for both arrangements
			defineGlobal("covariance_mutation_inversion_N", freq_I*(1-freq_I)*H_INV*S_INV_scaled*(mean_fitness_mutation_IN-mean_fitness_mutation_NN));

			defineGlobal("covariance_out_of_marginal_fitness_I",covariance_mutation_inversion_I/(marginal_fitness_inversion_I*(1-fitness_load_I))); // Relative strength of the interaction between mutation and inversion comparing with the marginal fitnesses of both forces independently for both arrangements
			defineGlobal("covariance_out_of_marginal_fitness_N",covariance_mutation_inversion_N/(marginal_fitness_inversion_N*(1-fitness_load_N)));

			defineGlobal("effective_selection",mean_fitness_global_II/mean_fitness_global_NN-1);
			defineGlobal("effective_selection_formula",AnalyticalEffectiveSelection(II_individuals));
			defineGlobal("effective_dominance",(mean_fitness_global_IN/mean_fitness_global_NN -1)/(mean_fitness_global_II/mean_fitness_global_NN -1));
			defineGlobal("gamma",(effective_dominance -1)*effective_selection);
			defineGlobal("dominance_variance",(mean_fitness_global_NN-1)^2 + (mean_fitness_global_IN-(1+S_INV_scaled*H_INV))^2 + (mean_fitness_global_II-(1+S_INV_scaled))^2);

		}
	}
}




