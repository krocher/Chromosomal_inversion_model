// Modelling chromosomal inversions in bi-allelic populations (continent-island model)
initialize() {
	// setSeed(9151250013170199950);
	setSeed(12345);

	if (!exists("Rep")) defineConstant("Rep",2);  // Identifier of the simulation amongst simulations with identical parameters
	defineConstant("FileName","output_test_K1_20e3_K2_20e3_chrom_length_3e6_inv_length_2e6_recrate_1e8_mutrate_1e8_s_0001_h_0_sinv_005_mig_0005_freqinv_005_scaling_5.csv");  // Suffix for the name of the generated files
	
	defineConstant("Q", 5.0);  // Scaling factor

	defineGlobal("Mu",1e-5);  // Mutation rate
	defineGlobal("R",1e-5);   // Recombination rate
	defineConstant("L",3e3);   // Sequence length
	defineConstant("I",0.05);  // Initial proportion of inverted arrangements in population 2
	defineConstant("INV_LENGTH",2e3);   // Inversion length
	defineConstant("INV_START", asInteger(L/2 - INV_LENGTH/2));  // Beginning position of the inversion
	defineConstant("INV_END", INV_START + INV_LENGTH - 1);  // End position of the inversion
	defineConstant("Double_Crossover",F);

	// -- Demographic parameters --
	
	defineGlobal("N",20e3);  // Population size
	defineGlobal("m12",0.005);   // Migration rate from population P1 to P2
	defineGlobal("m13",m12);   // Migration rate from population P1 to P3
	defineConstant("thirdPopControl", F);	// Boolean describing whether there is a third population or not

	// -- Deleterious Mutations --

	defineGlobal("H",0.0);  // Dominance of the mutations
	defineGlobal("S", -0.001); // Selection coefficient for the mutations

	// -- Inversion parameters --
	defineGlobal("H_INV",0.5);  // Dominance of the inversion
	defineGlobal("S_INV", 0.05); // Selection coefficient for the inversion


	// -- Time parameters
	defineGlobal("T_MAX", 150e3); // Time of simulation end
	defineGlobal("LOG_INTERVAL", 5e3); // Time interval for logging inversion frequencies and number of deleterious mutations
	defineGlobal("T_INV", 50e3);  // Burn-in time before introducing inversions
	

	// --- Scaled Parameters --- 

	// Population & Time: Divide by Q
	defineGlobal("N", asInteger(N / Q));
    defineConstant("T_MAX_scaled", asInteger(T_MAX / Q));
	defineConstant("LOG_INTERVAL_scaled", asInteger(LOG_INTERVAL / Q));
    defineConstant("T_INV_scaled", asInteger(T_INV / Q));

	// Rates & Selection: Multiply by Q
	defineGlobal("S", S * Q);
    defineGlobal("S_INV", S_INV * Q);
    defineGlobal("Mu", Mu * Q);
    defineGlobal("R", R * Q);
	defineGlobal("m12", m12 * Q);
	defineGlobal("m13", m13 * Q);

	// Safety check: ensure fitness is strictly positive
	if (1+S*Q <= 0)	stop("Scaling Error: Scaled deleterious selection coefficient makes individuals lethal (1+S<=0).");
	if (1+S_INV*Q <= 0) stop("Scaling Error: Scaled inversion selection coefficient makes individuals lethal (1+S_INV<=0).");


	// -- Mutation Type Definitions: to model biallelic loci --
	
	initializeMutationType("m1", H, "f", S);   // Defining deleterious mutations
	m1.convertToSubstitution = F;    // Allowing loci to have back-mutations after one allele is fixed
	m1.color = "red";
	
	initializeMutationType("m2",H,"f",S);   // Mutations that will be created in the haplosome
	m2.convertToSubstitution = F;      // Same as earlier
	m2.color = "cornflowerblue";
	

	// Markers for the chromosomal inversion boundaries
	initializeMutationType("m3",H_INV,"f",S_INV);   // Start marker
	initializeMutationType("m4",H_INV,"f",0.0);   // End marker
	c(m3,m4).convertToSubstitution = T;    // Inversion can get fixed, replace by F if we wanted double/back-inversions
	c(m3,m4).color = "yellow";
	
	
	initializeGenomicElementType("g1", m2, 1.0);    // Defining the genomic element on which deleterious mutations will appear
	initializeGenomicElement(g1, 0,L-1); // uniform chromosome with uniform recombination
	

	initializeMutationRate(Mu);

	initializeRecombinationRate(R);

}


1 early() {
	// Create subpopulations
	sim.addSubpop("p1", N);
	sim.addSubpop("p2", N);  // Creating 2 or 3 subpopulations of same size
	if(thirdPopControl==T) sim.addSubpop("p3", N);
	
	// Apply migration rates between populations
	p2.setMigrationRates(p1,m12);    // Setting the migration rate from the continent to the island
	if(thirdPopControl==T) p3.setMigrationRates(p1, mig13);   	// migration p1 -> p3 (non-inversion island)

	// -- Mutation Template Generation --

	target = p1.haplosomes[0];
	target.addNewDrawnMutation(m1, 0:(L-1));
	defineConstant("MUT", target.mutations);   // Creating the structure that will be used in all haplosomes
	target.removeMutations();   // Removing , all haplosomes will be "aa" by default
	

	// -- Logging Setup --

	updateGlobal();  // Updating all global variables


	// log results for inversion frequencies
	log = community.createLogFile(paste("/home/taubier/Documents/SAUVEGARDES_STAGIAIRES/Kilian/Results/Result_files/freq_",FileName,"Rep",Rep,".csv"), logInterval = LOG_INTERVAL);
	log.addTick();
	log.addCustomColumn("inv_freq","inv_freq;");  // Frequency of the inverted arrangement amongst haplosomes
	log.addCustomColumn("n_non_inv_haplosomes", "n_non_inv_haplosomes;");
	log.addCustomColumn("n_mut_per_non_inv_haplosome","n_mut_per_non_inv_haplosome;");
	log.addCustomColumn("n_inv_haplosomes", "n_inv_haplosomes;");
	log.addCustomColumn("n_mut_per_inv_haplosome","n_mut_per_inv_haplosome;");
	log.addCustomColumn("inv_marginal_fitness_inv_inversion","inv_marginal_fitness_inv_inversion;");
    log.addCustomColumn("non_inv_marginal_fitness_inversion","non_inv_marginal_fitness_inversion;");
	log.addCustomColumn("mean_fitness_mutation_II","mean_fitness_mutation_II;");
	log.addCustomColumn("mean_fitness_mutation_IN","mean_fitness_mutation_IN;");
	log.addCustomColumn("mean_fitness_mutation_NN","mean_fitness_mutation_NN;");
	log.addCustomColumn("fitness_load_I","fitness_load_I;");
	log.addCustomColumn("fitness_load_N","fitness_load_N;");
	log.addCustomColumn("freq_homozygous_mut_II","freq_homozygous_mut_II;");
	log.addCustomColumn("freq_homozygous_mut_IN","freq_homozygous_mut_IN;");
	log.addCustomColumn("freq_homozygous_mut_NN","freq_homozygous_mut_NN;");
	log.addCustomColumn("mean_fitness_global_II","mean_fitness_global_II;");
	log.addCustomColumn("mean_fitness_global_IN","mean_fitness_global_IN;");
	log.addCustomColumn("mean_fitness_global_NN","mean_fitness_global_NN;");
	


	// proportion of simulations with inverted haplosomes still existing (in Bash)
}

T_INV_scaled late() {
	inverted = sample(p2.haplosomes,asInteger(2*I*N));    // Inverting some of the haplosomes
	inverted.addNewDrawnMutation(m3, INV_START);
	inverted.addNewDrawnMutation(m4, INV_END);
}

// Replacing the SLiM default mutation function by one that returns the opposite allele from the one previously present
mutation(m2) {
	if (haplosome.containsMarkerMutation(m1,mut.position))
		return T;
	return MUT[mut.position];
}

T_INV_scaled:T_MAX_scaled late() {
	if (sim.countOfMutationsOfType(m3)==0) {
		writeFile("/home/taubier/Documents/SAUVEGARDES_STAGIAIRES/Kilian/Results/Result_files/last_generation.txt",paste("Time of loss of the inversion","(Rep ",Rep,"): ", sim.cycle));   // Exporting into a file the time of loss of the inversion, 
		sim.simulationFinished();
	}
}

recombination() {
	gm1 = haplosome1.containsMarkerMutation(m3, INV_START);
	gm2 = haplosome2.containsMarkerMutation(m3, INV_START);

	if (!(gm1 | gm2)) {
		// homozygote non-inverted: recombination is not affected
		return F;
	}
	inInv = (breakpoints > INV_START) & (breakpoints <= INV_END);
	if (Double_Crossover) {
		if (sum(inInv) % 2 == 0) {
			return F;  // if there is an even number of recombinations in the inversion; it leads to viable gametes, therefore recombination may not be suppressed
		}
		if (gm1 & gm2) {
		// homozygote inverted: 2 breakpoints are added at the beginning and the end of the inversion to get the correct base at both ends of the inversion
			left = (breakpoints == INV_START);
			right = (breakpoints == INV_END + 1);
			breakpoints = sort(c(breakpoints[!(left | right)],
				c(INV_START, INV_END + 1)[c(sum(left) == 0, sum(right) == 0)]));   // sort them in the right order depending on the haplosome arrangement
			return T;
		} else {
			// heterozygote inverted: resample to get an even # of breakpoints
			// this is *recursive*: it calls this recombination callback again!
			breakpoints = sim.chromosomes.drawBreakpoints(individual);
		}
		return T;
	} else {
		if (!any(inInv)) {
			return F;
		}
		if (sum(inInv) % 2 == 0) {
			if (gm1 != gm2) {
				breakpoints = breakpoints[!inInv];
				return T; 
			} else {
				return F;
			}
		}  
		if (gm1 & gm2) {
			// homozygote inverted: 2 breakpoints are added at the beginning and the end of the inversion to get the correct base at both ends of the inversion
			left = (breakpoints == INV_START);
			right = (breakpoints == INV_END + 1);
			breakpoints = sort(c(breakpoints[!(left | right)],
				c(INV_START, INV_END + 1)[c(sum(left) == 0, sum(right) == 0)]));   // sort them in the right order depending on the haplosome arrangement
			return T;
		} else {
			breakpoints = breakpoints[!inInv];
			return T;  
		}	
	}	
}


late() {
	m2muts = sim.mutationsOfType(m2);   // Implementing back-mutations from A to a
	
	// do we have any m2 mutations segregating?
	// if so, we have m1/m2 stacked mutations to remove
	if (m2muts.length() > 0)
	{
		haplosomes = sim.subpopulations.haplosomes;
		counts = haplosomes.countOfMutationsOfType(m2);
		hasStacked = haplosomes[counts > 0];
		
		for (haplosome in hasStacked)
		{
			stacked_m2 = haplosome.mutationsOfType(m2);
			stackPositions = stacked_m2.position;
			all_m1 = haplosome.mutationsOfType(m1);
			s = (match(all_m1.position, stackPositions) >= 0);
			stacked_m1 = all_m1[s];
			haplosome.removeMutations(c(stacked_m2, stacked_m1));
		}
	}

	if (sim.cycle % LOG_INTERVAL_scaled == 1)
	{
		updateGlobal();
	}

		
}

// Simulation stop
T_MAX_scaled late() {
 }


 // -- Utility functions --

function (float)Fitness(No<Individual> individuals) {
	if (individuals.size() == 0) {
		return(1.0);
	}
	a = asFloat(1:(individuals.size()));
	for (i in (1:(individuals.size()))) {
		homozygous_mut = individuals[i-1].mutationsFromHaplosomes("homozygous",m1);
		heterozygous_mut = individuals[i-1].mutationsFromHaplosomes("heterozygous",m1);
		homozygous_mutations_number = homozygous_mut[(homozygous_mut.position >= INV_START) & (homozygous_mut.position <= INV_END)].size();
		heterozygous_mutations_number = heterozygous_mut[(heterozygous_mut.position >= INV_START) & (heterozygous_mut.position <= INV_END)].size();
		a[i-1] = (1+S)^(homozygous_mutations_number)*(1+H*S)^(heterozygous_mutations_number);
	}
	return(mean(a));
}


function (void)updateGlobal(void) {   // Updating all global variables
	p2Individuals = sim.subpopulations[1].individuals;
	II_individuals = p2Individuals[p2Individuals.countOfMutationsOfType(m3) == 2];     // Separating II, IN and NN individuals
	IN_individuals = p2Individuals[p2Individuals.countOfMutationsOfType(m3) == 1];
	NN_individuals = p2Individuals[p2Individuals.countOfMutationsOfType(m3) == 0];
	haplosomes = p2.haplosomes;
	counts = haplosomes.countOfMutationsOfType(m3);
	inv = haplosomes[counts > 0];
	non_inv = haplosomes[counts == 0];
	pos_inv = inv.positionsOfMutationsOfType(m1); 
	pos_non_inv = non_inv.positionsOfMutationsOfType(m1);

	defineGlobal("inv_freq", sum(p2Individuals.countOfMutationsOfType(m3))/(p2.haplosomes.size()));
	defineGlobal("n_non_inv_haplosomes",non_inv.size());
	defineGlobal("n_mut_per_non_inv_haplosome",sum((pos_non_inv >= INV_START) & (pos_non_inv <= INV_END))/(non_inv.size()));
	defineGlobal("non_inv_marginal_fitness_inversion", 1*(1-inv_freq)+(1+H_INV*S_INV)*inv_freq);
	defineGlobal("n_inv_haplosomes", inv.size());
	defineGlobal("n_mut_per_inv_haplosome", sum((pos_inv >= INV_START) & (pos_inv <= INV_END))/(inv.size()));
	defineGlobal("inv_marginal_fitness_inv_inversion", (1+S_INV)*inv_freq + (1+H_INV*S_INV)*(1-inv_freq));

	defineGlobal("mean_fitness_mutation_II",Fitness(II_individuals));
	defineGlobal("mean_fitness_mutation_IN",Fitness(IN_individuals));
	defineGlobal("mean_fitness_mutation_NN",Fitness(NN_individuals));

	defineGlobal("fitness_load_I",1-(mean_fitness_mutation_II*inv_freq + mean_fitness_mutation_IN*(1-inv_freq)));
	defineGlobal("fitness_load_N",1-(mean_fitness_mutation_IN*inv_freq + mean_fitness_mutation_NN*(1-inv_freq)));

	defineGlobal("mean_fitness_global_II",(1+S_INV)*Fitness(II_individuals));
	defineGlobal("mean_fitness_global_IN",(1+H_INV*S_INV)*Fitness(IN_individuals));
	defineGlobal("mean_fitness_global_NN",1*Fitness(NN_individuals));

	homozygous_mut_II = II_individuals.mutationsFromHaplosomes("homozygous",m1);
	heterozygous_mut_II = II_individuals.mutationsFromHaplosomes("heterozygous",m1);
	all_mut_II = II_individuals.mutationsFromHaplosomes("all",m1);
	
	homozygous_mut_IN = IN_individuals.mutationsFromHaplosomes("homozygous",m1);
	heterozygous_mut_IN = IN_individuals.mutationsFromHaplosomes("heterozygous",m1);
	all_mut_IN = IN_individuals.mutationsFromHaplosomes("all",m1);
	
	homozygous_mut_NN = NN_individuals.mutationsFromHaplosomes("homozygous",m1);
	heterozygous_mut_NN = NN_individuals.mutationsFromHaplosomes("heterozygous",m1);
	all_mut_NN = NN_individuals.mutationsFromHaplosomes("all",m1);

	homozygous_mutations_number_II = homozygous_mut_II[(homozygous_mut_II.position >= INV_START) & (homozygous_mut_II.position <= INV_END)].size();
	heterozygous_mutations_number_II = heterozygous_mut_II[(heterozygous_mut_II.position >= INV_START) & (heterozygous_mut_II.position <= INV_END)].size();
	total_mutations_number_II = all_mut_II[(all_mut_II.position >= INV_START) & (all_mut_II.position <= INV_END)];
	
	homozygous_mutations_number_IN = homozygous_mut_IN[(homozygous_mut_IN.position >= INV_START) & (homozygous_mut_IN.position <= INV_END)].size();
	heterozygous_mutations_number_IN = heterozygous_mut_IN[(heterozygous_mut_IN.position >= INV_START) & (heterozygous_mut_IN.position <= INV_END)].size();
	all_mut_IN = all_mut_IN[(all_mut_IN.position >= INV_START) & (all_mut_IN.position <= INV_END)];
	
	homozygous_mutations_number_NN = homozygous_mut_NN[(homozygous_mut_NN.position >= INV_START) & (homozygous_mut_NN.position <= INV_END)].size();
	heterozygous_mutations_number_NN = heterozygous_mut_NN[(heterozygous_mut_NN.position >= INV_START) & (heterozygous_mut_NN.position <= INV_END)].size();
	all_mut_NN = all_mut_NN[(all_mut_NN.position >= INV_START) & (all_mut_NN.position <= INV_END)];

	defineGlobal("freq_homozygous_mut_II",homozygous_mutations_number_II/(homozygous_mutations_number_II + heterozygous_mutations_number_II));
	defineGlobal("freq_homozygous_mut_IN",homozygous_mutations_number_IN/(homozygous_mutations_number_IN + heterozygous_mutations_number_IN));
	defineGlobal("freq_homozygous_mut_NN",homozygous_mutations_number_NN/(homozygous_mutations_number_NN + heterozygous_mutations_number_NN));

}




